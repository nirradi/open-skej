.env
.vscode

# Orchestration state (plans, archive, harness scripts) lives in the sibling
# private repo `skej-ops`, reached through this per-checkout symlink. It is
# deliberately untracked: every worktree points at ONE working copy so agents
# see each other's plan edits live, with no commit/merge/pull round-trip.
# Create it in a new worktree with: ln -sfn ../skej-ops ops
ops

# Output of the AI generation loop: candidate rules awaiting human review. Untracked on purpose —
# a generated draft committed by accident is a draft that looks like it was accepted, and nothing
# in here is imported by the engine or the app. Adopting one means porting it into rules/rules/.
rules/generated/

# Python
venv/
__pycache__/
*.pyc
.pytest_cache/

# Node
node_modules/

# Local SQLite databases
*.db
*.db-wal
*.db-shm
