# Base URL of the FastAPI backend. Defaults to http://localhost:8000 when unset.
VITE_API_BASE_URL=http://localhost:8000

# --- Auth0 -------------------------------------------------------------------
# All three are required; the app refuses to boot without them and says which
# are missing. Run `python scripts/auth0_provision.py` in app/backend to create
# the tenant objects — it prints these three lines ready to paste.
#
# Vite reads these at build time, so restart the dev server after changing them.

# Tenant domain, without a scheme or a trailing slash.
VITE_AUTH0_DOMAIN=dev-oag8ojxnvqp4okwn.us.auth0.com

# Client id of the `open-skej-web` SPA application. Public by design — it ends
# up in the bundle, and Auth0 treats a SPA client as having no secret.
VITE_AUTH0_CLIENT_ID=

# API identifier the access token is minted for. MUST match AUTH0_API_AUDIENCE
# in app/backend/.env. Without it the SDK hands out an opaque /userinfo token
# instead of a JWT, and every API call 401s behind a login that looked fine.
VITE_AUTH0_AUDIENCE=https://api.open-skej.dev

# --- Sandbox auth (Playwright / manual QA only) -------------------------------
# Set to exactly "true" to authenticate against a sandbox-signed token instead
# of Auth0 — see src/auth/sandboxConfig.ts. Mutually exclusive with the three
# VITE_AUTH0_* variables above: set this alongside any of them and the app
# refuses to boot rather than picking one. Requires the backend to be running
# with SANDBOX_AUTH=true (app/backend/.env).
# VITE_SANDBOX_AUTH=true
